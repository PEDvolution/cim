ped:panelOrientation rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf energy:inclination;
                     rdfs:domain ped:PVSystemCharacteristics ;
                     rdfs:range [ rdf:type rdfs:Datatype ;
                                  owl:oneOf [ rdf:type rdf:List ;
                                              rdf:first 0 ;
                                              rdf:rest [ rdf:type rdf:List ;
                                                         rdf:first 135 ;
                                                         rdf:rest [ rdf:type rdf:List ;
                                                                    rdf:first 180 ;
                                                                    rdf:rest [ rdf:type rdf:List ;
                                                                               rdf:first 225 ;
                                                                               rdf:rest [ rdf:type rdf:List ;
                                                                                          rdf:first 270 ;
                                                                                          rdf:rest [ rdf:type rdf:List ;
                                                                                                     rdf:first 315 ;
                                                                                                     rdf:rest [ rdf:type rdf:List ;
                                                                                                                rdf:first 45 ;
                                                                                                                rdf:rest [ rdf:type rdf:List ;
                                                                                                                           rdf:first 90 ;
                                                                                                                           rdf:rest rdf:nil
                                                                                                                         ]
                                                                                                              ]
                                                                                                   ]
                                                                                        ]
                                                                             ]
                                                                  ]
                                                       ]
                                            ]
                                ] ;
                     rdfs:comment "The azimuthal orientation (North, South East)."@en ;
                     rdfs:label "panelOrientation"@en .

