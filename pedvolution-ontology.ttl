########################################## Charger type ##################################################
ped:Level1 rdf:type owl:NamedIndividual ,
                    ped:ElectricVehicleChargerType ;
           rdfs:comment "Level 1 charging (up to 2.5kW of AC power on 1 phase 120V input)."@en ;
           rdfs:label "Level 1 Charger"@en .


ped:Level2 rdf:type owl:NamedIndividual ,
                    ped:ElectricVehicleChargerType ;
           rdfs:comment "Level 2 charging (direct AC power but can use higher voltage and up to 3 phases)."@en ;
           rdfs:label "Level 2 Charger"@en .


ped:Level3 rdf:type owl:NamedIndividual ,
                    ped:ElectricVehicleChargerType ;
           rdfs:comment "Level 3 charging (direct DC power)."@en ;
           rdfs:label "Level 3 Charger"@en .

