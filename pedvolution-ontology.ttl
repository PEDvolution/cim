  rdfs:comment "Association of BatterySystemCharacteristics to a ped DistrictTechnicalCharacteristics or Building unit BuildingEnergyAssetCharacteristics"@en .

ped:includesElectricVehicleChargingStations rdf:type owl:ObjectProperty ;
                                            rdfs:domain ped:EVChargingCharacteristics ;
                                            rdfs:range ped:ElectricVehicleChargingStation;
                                            rdfs:comment "Links ElectricalVehical Charging Stations to EVChargingCharacteristics."@en ;
                                            rdfs:label "includesElectricVehicleChargingStations"@en   .


ped:hasBuildingConstructionCharacteristics rdf:type owl:ObjectProperty ;
                                                rdfs:domain ped:BuildingUnit ;
                                                rdfs:range ped:BuildingConstructionCharacteristics;
                                                rdfs:comment "Links Building Construction Characteristics  to a building";
                                                rdfs:label "hasBuildingConstructionCharacteristics"   . 
 

ped:hasGeoSpatialData rdf:type owl:ObjectProperty ;
                                                rdfs:domain ped:Ped;
                                                rdfs:range ped:GeoSpatialData .


ped:Capacity_In_KW rdf:type owl:ObjectProperty ;
                                   rdfs:domain  ped:Heat_Generator,ped:CHP_Plant,ped:Hydro_Power_Plant ;
                                   rdfs:range qudt:QuantityValue ;
                                   rdfs:comment "Installed Capacity of any other heat generator available."@en ;
                                   rdfs:label "Capacity In KW"@en .


ped:Thermal_Capacity_In_KW rdf:type owl:ObjectProperty ;
                                   rdfs:domain ped:Heat_Generator,ped:CHP_Plant;
                                   rdfs:range qudt:QuantityValue ;
                                   rdfs:comment "Thermal Capacity of station."@en ;
                                   rdfs:label "Thermal Capacity In KW"@en .




ped:Heat_Loss_In_KW_Per_Meter rdf:type owl:ObjectProperty ;
                                       rdfs:domain ped:Pipe ;
                                       rdfs:range qudt:QuantityValue ;
                                       rdfs:comment "Amount of heat lost per meter of pipe, affecting overall system efficiency (KW/m) ."@en ;
                                       rdfs:label "Heat Loss In Pipes in KW/m"@en .

ped:Heat_Loss_Percentage rdf:type owl:ObjectProperty ;
    rdfs:domain ped:Pipe ;
    rdfs:range qudt:QuantityValue ;
    rdfs:comment "Amount of heat lost per meter of pipe, affecting overall system efficiency (%) ."@en ;
    rdfs:label "Heat Loss In Pipes Percent"@en .


ped:Cooling_Capacity rdf:type owl:ObjectProperty ;
                    rdfs:domain ped:HVAC_Equipment ;
                    rdfs:range qudt:QuantityValue ;
                    rdfs:comment "Maximum power can supply in KW ."@en ;
                    rdfs:label "Cooling Power in KW "@en .


ped:Heating_Capacity rdf:type owl:ObjectProperty ;
                    rdfs:domain ped:HVAC_Equipment ;
                    rdfs:range qudt:QuantityValue ;
                    rdfs:comment "Maximum power can supply in KW ."@en ;
                    rdfs:label "Heating Power in KW "@en .


ped:hasBattery rdf:type owl:ObjectProperty ;
                                            rdfs:domain ped:BatterySystemCharacteristics;
                                            rdfs:range lec:Battery;
                                            rdfs:comment "Links Battery System Characteristics to batteries."@en ;
                                            rdfs:label "hasBattery"@en   .

ped:hasBatteries rdf:type owl:ObjectProperty ;
                                            rdfs:domain ped:BatterySystemCharacteristics;
                                            rdfs:range lec:Battery;
                                            rdfs:comment "Links Battery System Characteristics to batteries."@en ;
                                            rdfs:label "hasBattery"@en   .


ped:hasElectricVehicleChargerDirectionalityShape rdf:type owl:ObjectProperty ;
                                                 rdfs:domain ped:ElectricVehicleChargingStation ;
                                                 rdfs:range brick:electricVehicleChargerDirectionality .

ped:hasElectricVehicleChargerType rdf:type owl:ObjectProperty ;
                                  rdfs:domain ped:ElectricVehicleSupplyEquipment ;
                                  rdfs:range ped:ElectricVehicleChargerType ;
                                  rdfs:comment "Indicates which type of EVSE charger this station provides, such as Level 1, Level 2, or Level 3."@en ;
                                  rdfs:label "has electric vehicle charger type"@en .

ped:hasElectricVehicleChargingPort rdf:type owl:ObjectProperty ;
                                   rdfs:domain ped:ElectricVehicleSupplyEquipment ;
                                   rdfs:range ped:ElectricVehicleChargingPort ;
                                   rdfs:comment "Indicates the relation between an Electric Vehicle Supply Equipment and one or more Electric Vehicle Charging Ports ."@en ;
                                   rdfs:label "hasElectricVehicleChargingPort"@en .


ped:hasElectricVehicleConnectorTypeShape rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf bsh:haselectricVehicleConnectorTypeShape ;
                                         rdfs:domain ped:ElectricVehicleChargingPort ;
                                         rdfs:range ped:ElectricVehicleConnectorTypeShape ;
                                         rdfs:comment "Indicates the type of EVSE connector shape used at the charging station, such as Type 1 (CSS), Type 2 (CSS), GB/T, Type 1 (SAE J1772), Type 2 (IEC 62196), CHAdeMO, CCS, Tesla Supercharger, or Wireless."@en ;
                                         rdfs:label "has electric vehicle connector type shape"@en .


ped:inputVoltageUnit rdf:type owl:ObjectProperty ;
                     rdfs:domain ped:ElectricVehicleSupplyEquipment ;
                     rdfs:range qudt:QuantityValue ;
                     rdfs:comment "The unit of measurement for input voltage (always Volts)."@en ;
                     rdfs:label "Input Voltage Unit"@en .




ped:powerOutput rdf:type owl:ObjectProperty ;
                rdfs:domain ped:ElectricVehicleSupplyEquipment ;
                rdfs:range qudt:QuantityValue ;
                rdfs:comment "How much power a charger can generate, expressed in kilowatts (kW)."@en ;
                rdfs:label "Power Output"@en .


ped:batterySize rdf:type owl:ObjectProperty ;
                         rdfs:domain ped:ElectricVehicleSupplyEquipment ;
                         rdfs:comment "Battery in KWh."@en;
                         rdfs:label "Battery size"@en;
                         rdfs:range qudt:QuantityValue .


ped:dailyUsage  rdf:type owl:ObjectProperty ;
                         rdfs:domain ped:ElectricVehicleSupplyEquipment ;
                         rdfs:comment "Daily usage in KWh."@en;
                         rdfs:label "Daily usage"@en;
                         rdfs:range qudt:QuantityValue ; .


ped:population rdf:type owl:ObjectProperty ;
                         rdfs:domain ped:EVChargingCharacteristics;
                         rdfs:comment "The population in area of interest."@en;
                         rdfs:label "population"@en;
                         rdfs:range qudt:QuantityValue .


ped:consistsEVSupplyEquipment rdf:type owl:ObjectProperty ;
               rdfs:domain ped:ElectricVehicleChargingStation ;
               rdfs:range ped:ElectricVehicleSupplyEquipment ;
               rdfs:comment "Links Electric Vehicle Supply Equipment to Electric Vehicle Charging Station."@en ;
               rdfs:label "consistsEVSupplyEquipment"@en .


ped:Temperature_In_Celsius rdf:type owl:ObjectProperty ;
              rdfs:domain ped:GeothermalPlant,ped:IndustrialProcess;
              rdfs:range qudt:QuantityValue;
              rdfs:comment "Temperature In Celsius."@en ;
              rdfs:label "Temperature In Celsius"@en .

ped:Waste_Heat_In_KW rdf:type owl:ObjectProperty ;
              rdfs:domain ped:IndustrialProcess;
              rdfs:range qudt:QuantityValue;
              rdfs:comment "Waste_Heat_In_KW."@en ;
              rdfs:label "Waste Heat In KW"@en .

ped:Inlet_Temperature rdf:type owl:ObjectProperty ;
              rdfs:domain ped:Building;
              rdfs:range qudt:QuantityValue ;
              rdfs:comment "Source temperature level at the building level."@en ;
              rdfs:label "Inlet Temperature In Celsius"@en .

ped:Outlet_Temperature rdf:type owl:ObjectProperty ;
              rdfs:domain ped:Building;
              rdfs:range qudt:QuantityValue ;
              rdfs:comment "Return temperature level at the building level."@en ;
              rdfs:label "Outlet Temperature In Celsius"@en .

ped:industrialProcesses rdf:type owl:ObjectProperty ;
                  rdfs:domain ped:HeatRecoveryPotentialCharacteristics;
                  rdfs:range ped:IndustrialProcess ;
                  rdfs:comment "industrial Processes."@en ;
                  rdfs:label "industrialProcesses"@en .

ped:geothermalPlants rdf:type owl:ObjectProperty;
              rdfs:domain ped:HeatRecoveryPotentialCharacteristics;
              rdfs:range ped:GeothermalPlant ;
              rdfs:comment "Geothermal Plant."@en ;
              rdfs:label "GeothermalPlant"@en .

ped:hasHeatRecoveryPotentialCharacteristics rdf:type owl:ObjectProperty;
     rdfs:domain ped:DistrictTechnicalCharacteristics;
     rdfs:range ped:HeatRecoveryPotentialCharacteristics;
     rdfs:comment "Links District Technical Characteristics to Heat Recovery Potential Characteristics."@en ;
     rdfs:label "hasHeatRecoveryPotentialCharacteristics"@en .

ped:hasWasteMeter rdf:type owl:ObjectProperty ;
              rdfs:domain ped:IndustrialProcess;
              rdfs:range ped:Waste_Meter;
              rdfs:comment "Links a IndustrialProcess to a waste meter device."@en ;
              rdfs:label "hasWasteMeter"@en .


