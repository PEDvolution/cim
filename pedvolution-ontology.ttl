                   rdfs:comment "Extremely Fast Fast charging speed. "@en ;
                   rdfs:isDefinedBy ped: ;
                   rdfs:label "Extremely Fast"@en .


prop:UltraFast a owl:NamedIndividual, prop:ChargingSpeedCategory ;
