
@prefix g: <http://www.opengis.net/gml#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix gml: <http://www.opengis.net/ont/gml#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ped: <https://github.com/PEDvolution/cim/pedvolution-ontology.ttl> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix core: <htttp://example.org/ontology/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix s4city: <https://saref.etsi.org/saref4city/> .
@prefix s4ener: <https://saref.etsi.org/saref4ener/> .
@prefix citygml: <http://www.opengis.net/citygml/1.0#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix energy:<http://sig3d.org> .
@prefix lec: <https://raw.githubusercontent.com/FZ-HANNOU/Omega-X/main/LocalEnergyCommunitiesOntology/LocalEnergyCommunitiesOntology-1.0.ttl> .
@prefix prop: <https://w3id.org/omega-x/Ontology/Property> .
@prefix sf: <http://www.opengis.net/ont/sf#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix bsh: <https://brickschema.org/schema/BrickShape#> .
@prefix em: <https://w3id.org/omega-x/ontology/Electromobility/> .
@prefix rec: <https://w3id.org/rec#> .
@prefix qudt: <https://qudt.org/schema/qudt/> .


@base <http://example.org/ontology#> .


<http://example.org/ontology#> rdf:type owl:Ontology ;
                                owl:versionInfo "v3.1.1" ;
                                dcterms:issued "2026-02-11"^^xsd:date ;
                                dcterms:modified "2026-05-29"^^xsd:date ;
                                dcterms:title "PED   PEDVolution ontology"@en ;
                                owl:imports    <http://www.opengis.net/ont/gml> ,
                                s4city: .      

                          


################################# Classes #####################################################
###  https://pedvolution.eu/ontology/Ped
ped:Ped rdf:type owl:Class ;
        rdfs:subClassOf s4city:District .

###  cPed
ped:SuperPed rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty ped:hasPeds ;
                          owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                          owl:onClass ped:Ped
                        ],

 s4city:District;
 rdfs:comment "Super Ped."@en ;
 rdfs:label "Super Ped"@en .

ped:Substation rdf:type owl:Class ;
               rdfs:comment "Substation."@en ;
               rdfs:label "Substation "@en .

ped:Pipe rdf:type owl:Class ;
         rdfs:comment "Pipe."@en ;
         rdfs:label "Pipe "@en .



ped:Building rdf:type owl:Class ;
             rdfs:subClassOf geo:Feature,rec:Building; 
             rdfs:comment "An independent unit of the built environment with a characteristic spatial structure"@en ;
             rdfs:label "Building"@en .

ped:BuildingUnit rdf:type owl:Class ;
                      rdfs:subClassOf energy:BuildingUnit;
                      rdfs:comment "A building unit is a part of usage zone, such as dwelling or workplace, which is related to a single occupant entity."@en ;
                      rdfs:label "Building Unit"@en .

ped:DistrictTechnicalCharacteristics rdf:type owl:Class;
               rdfs:comment "A class associated to Technical Characteristics of a District Area."@en ;
               rdfs:label "DistrictTechnicalCharacteristics"@en .


ped:DistrictHeatingAndCoolingInfrastructure rdf:type owl:Class ;
                                            rdfs:comment "A class associated to District Heating And Cooling Infrastructure of a District Area."@en ;
                                            rdfs:label "DistrictHeatingAndCoolingInfrastructure"@en .


ped:BuildingEnergyAssetCharacteristics rdf:type owl:Class ;
                                       rdfs:comment "Building Energy Asset Characteristics."@en ;
                                       rdfs:label "BuildingEnergyAssetCharacteristics"@en .

ped:PVSystemCharacteristics rdf:type owl:Class ;
       rdfs:subClassOf geo:Feature;
       rdfs:comment "PV SystemCharacteristics."@en ;
       rdfs:label "PV System Characteristics"@en .
###


ped:EVChargingCharacteristics rdf:type owl:Class ;
                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                owl:onProperty ped:includesElectricVehicleChargingStations ;
                                                owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                owl:onClass ped:ElectricVehicleChargingStation
                                              ] ;
                                              
                              rdfs:comment "Electric Vehicle Charging Characteristics."@en ;
                              rdfs:label "EVChargingCharacteristics"@en .

ped:BatterySystemCharacteristics rdf:type owl:Class ;
                                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                   owl:onProperty ped:hasStorage ;
                                                   owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                   owl:onClass s4ener:Storage
                                                 ],
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty ped:hasBattery ;
                                                   owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                   owl:onClass lec:Battery;
                                                 ],
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty ped:hasBatteries ;
                                                   owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                   owl:onClass lec:Battery;
                                                 ] .
 


ped:BuildingConstructionCharacteristics rdf:type owl:Class ;
                                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                   owl:onProperty ped:hasBuildingConstructionCharacteristics ;
                                                   owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                   owl:onClass ped:BuildingUnit;
                                                 ] .


ped:HVACBuildingCharacteristics rdf:type owl:Class ;

                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:hasHVAC_System ;
                                                  owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                                  owl:onClass ped:HVAC_System
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Cooling_Season_Start_Date ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Cooling_Season_End_Date;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                  
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Heating_Season_Start_Date ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                  
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Heating_Season_End_Date;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                  
                                                ],

                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:AuxiliaryHeatingSystem ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                  
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:NumberOfRadiators;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:integer
                                                ];
                                         
                                                

                                rdfs:comment "HVAC Building Characteristics."@en ;
                                rdfs:label "HVAC Building Characteristics"@en .


ped:EnergyPrice rdf:type owl:Class ;
                rdfs:comment "Represents the cost of energy resources, categorized by type and sector." ;
                rdfs:label "EnergyPrice" .

ped:EnergyType rdf:type owl:Class ;
               rdfs:comment "Different categories of energy resources." ;
               rdfs:label "EnergyType" .


ped:EnergyUnit rdf:type owl:Class ;
               rdfs:comment "The unit of energy resources." ;
               rdfs:label "EnergyUnit" .



ped:GeoSpatialData rdf:type owl:Class .

ped:DistrictEnergyAsset rdf:type owl:Class ;
 rdfs:subClassOf geo:Feature ;
 rdfs:label "District Enegy Asset"@en .

ped:CHP_Plant rdf:type owl:Class ;
 rdfs:subClassOf ped:DistrictEnergyAsset;
 rdfs:label "CHP Plant"@en .

ped:Hydro_Power_Plant rdf:type owl:Class ;
 rdfs:subClassOf ped:DistrictEnergyAsset;
 rdfs:label "Hydro Power Plant"@en .

ped:ThermalEnergySource rdf:type owl:Class ;
 rdfs:subClassOf ped:DistrictEnergyAsset;
 rdfs:label "Thermal Energy Source"@en .

ped:Heat_Generator rdf:type owl:Class ;
 rdfs:subClassOf ped:DistrictEnergyAsset;
 rdfs:label "Heat Generator"@en .


ped:Heating_System_Efficiency rdf:type owl:Class ;
             rdfs:subClassOf bsh:EfficiencyShape ;  
             rdfs:comment "The percent efficiency of the conversion process (usually to power or energy) carried out by the entity"@en ;
             rdfs:label "Heating_System_Efficiency"@en .


ped:Cooling_System_Efficiency rdf:type owl:Class ;
             rdfs:subClassOf bsh:EfficiencyShape ;  
             rdfs:comment "The percent efficiency of the conversion process (usually to power or energy) carried out by the entity"@en ;
             rdfs:label "Cooling_System_Efficiency"@en .


ped:HVAC_Equipment rdf:type owl:Class ;
             rdfs:subClassOf brick:HVAC_Equipment ;  
             rdfs:comment "The equipment, distribution systems and terminals that provide, either collectively or individually, the processes of heating, ventilating or air conditioning to a building or portion of a building"@en ;
             rdfs:label "HVAC_Equipment"@en .

ped:Ventilation_System rdf:type owl:Class ;
                rdfs:subClassOf ped:HVAC_System, 
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Ventilation_System_Type;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                ];
                                                          
                rdfs:comment "Ventilation_System."@en ;
                rdfs:label "Ventilation_System"@en .


ped:Heating_System rdf:type owl:Class ;
                rdfs:subClassOf ped:HVAC_System, 
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Heating_System_Type;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                ];
                                                          
                rdfs:comment "Heating_System."@en ;
                rdfs:label "Heating_System"@en .

ped:Cooling_System rdf:type owl:Class ;
                rdfs:subClassOf ped:HVAC_System, 
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Cooling_System_Type;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange xsd:string
                                                ];
                                                          
                rdfs:comment "Cooling_System."@en ;
                rdfs:label "Cooling_System"@en .


ped:HVAC_System rdf:type owl:Class ;
                rdfs:subClassOf brick:Heating_Ventilation_Air_Conditioning_System, 
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:InstallationYear ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange  xsd:string
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:HVAC_Operating_Mode ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange  xsd:string
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Fuel_Source;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange  xsd:string
                                                ],
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Distribution_System ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange  xsd:string
                                                ]

                                                ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty ped:Control_System ;
                                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                                                  owl:onDataRange  xsd:string
                                                ];
                                                          
                rdfs:comment "The equipment, distribution systems and terminals that provide, either collectively or individually, the processes of heating, ventilating or air conditioning to a building or portion of a building."@en ;
                rdfs:label "HVAC_System"@en .

ped:ElectricVehicleConnectorTypeShape rdf:type owl:Class ;
                                      rdfs:subClassOf brick:ElectricVehicleConnectorTypeShape ;
                                      rdfs:comment "Represents different types of EVSE connector shapes, such as Type 1, Type 2, GB/T, CHAdeMO, CCS, Tesla Supercharger, and Wireless."@en ;
                                      rdfs:label "Electric Vehicle Connector Type Shape"@en .



brick:electricVehicleChargerDirectionality rdf:type owl:Class .

#bsh:haselectricVehicleChargerDirectionalityShape rdf:type owl:Class .

ped:ElectricVehicleChargingPort rdf:type owl:Class ;
                                rdfs:subClassOf brick:Electric_Vehicle_Charging_Port ;
                                rdfs:label "ElectricVehicleChargingPort"@en ;
                                <http://www.w3.org/2004/02/skos/core#definition> "An individual point of attachment for charging a single electric vehicle"@en .



ped:ElectricVehicleChargingStation rdf:type owl:Class ;
                                   rdfs:subClassOf em:ElectricVehicleChargingStation;
                                   rdfs:comment "(source eMIP) A Charging Station is a physical element, visible for the users, on which Charging Points are available. The Charging Station is also the  Human-Machine Interface  (HMI) between the charge infrastructure and the end users."@en ;
                                   rdfs:isDefinedBy ped: ;
                                   rdfs:label "Electric Vehicle Charging Station"@en ;
                                   rdfs:seeAlso <https://www.gireve.com/wp-content/uploads/2022/09/Gireve_Tech_eMIP-V0.7.4_ImplementationGuide_1.0.7_en.pdf> .

ped:ElectricVehicleSupplyEquipment rdf:type owl:Class ;
                                   rdfs:subClassOf em:ElectricVehicleSupplyEquipment;
                                   rdfs:isDefinedBy ped: ;
	                           rdfs:comment """(source eMIP) A Charging Point, synonym of EVSE (Electric Vehicle Supply Equipment), is the energy supply element. An electrical vehicle can connect to a point on one of its connector. A Charging Point may have several Charging Connectors but only one vehicle could be charged at a time on a Charging Point."""@en;
                                   rdfs:seeAlso <https://www.gireve.com/wp-content/uploads/2022/09/Gireve_Tech_eMIP-V0.7.4_ImplementationGuide_1.0.7_en.pdf>;
                                   rdfs:label "Electric Vehicle Supply Equipment (EVSE)"@en; .

ped:ElectricVehicleChargerType rdf:type owl:Class ;
                               rdfs:comment "Represents different types of EVSE chargers, such as Level 1, Level 2, and Level 3."@en ;
                               rdfs:label "Electric Vehicle Charger Type"@en .


ped:IndustrialProcess rdf:type owl:Class ;
               rdfs:subClassOf geo:Feature; 
               rdfs:comment "Industrial process such as manufacturing, power generation, chemical production."@en ;
               rdfs:label "Industrial Process "@en .

ped:GeothermalPlant rdf:type owl:Class ;
         rdfs:subClassOf geo:Feature, rec:Building; 
         rdfs:comment "GeothermalPlant."@en ;
         rdfs:label "Geothermal plant "@en .

ped:Waste_Meter rdf:type owl:Class ;
 rdfs:subClassOf brick:Waste_Meter ;
 rdfs:comment: "A Waste Meter is used for tracking and categorizing various waste types in a building, aiding in waste management facilitating waste reduction, recycling, and disposal  strategies."@en ;  
 rdfs:label:"Waste_Meter" .

ped:RenovationCharacteristics rdf:type owl:Class;
rdfs:comment "Renovation Characteristics"@en; 
rdfs:label "Renovation Characteristics"@en .

ped:WindowsCharacteristics rdf:type owl:Class;
rdfs:comment "Windows Characteristics"@en; 
rdfs:label "Windows Characteristics"@en .

ped:RoofCharacteristics rdf:type owl:Class;
rdfs:comment "Roof Characteristics"@en; 
rdfs:label "Roof Characteristics"@en .



ped:PostalAddress rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty ped:City ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty ped:Country ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty ped:addressLine1 ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty ped:postalCode ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty ped:addressLine2 ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ;
                  rdfs:comment "Physical address of the architecture (site, building, sub-building, entrance room, etc.)" ;
                  rdfs:label "Postal address"@en  .

ped:EnergyPerformanceCertification rdf:type owl:Class ;
                                        rdfs:comment "Energy performance certification."@en . 


################################## Datatype Properties #########################################

ped:hasEnergyPrice rdf:type owl:DatatypeProperty ;
                   rdfs:domain ped:EnergyPrice ;
                   rdfs:range xsd:float ;
                   rdfs:comment "Numerical value of the energy price." ;
                   rdfs:label "Has Energy Value" .



ped:isRegulatedBy rdf:type owl:DatatypeProperty ;
                  rdfs:domain ped:EnergyPrice ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Specifies the organization regulating this energy price." ;
                  rdfs:label "Is Regulated By" .

ped:Symbol rdf:type owl:DatatypeProperty ;
           rdfs:domain ped:EnergyUnit ;
           rdfs:range xsd:string ;
           rdfs:comment "Symbol representing the energy unit (e.g., €/kWh, CHF/kWh)." ;
           rdfs:label "Symbol" .




ped:hasStartDate rdf:type owl:DatatypeProperty ;
                 rdfs:domain ped:EnergyPrice ;
                 rdfs:range xsd:date ;
                 rdfs:comment "Start date of the energy price period (e.g., 2024-03-07)." ;
                 rdfs:label "Has Start Date" .

ped:hasEndDate rdf:type owl:DatatypeProperty ;
               rdfs:domain ped:EnergyPrice ;
               rdfs:range xsd:date ;
               rdfs:comment "End date of the energy price period (e.g., 2024-03-08)." ;
               rdfs:label "Has End Date" .

ped:hasTimeStamp rdf:type owl:DatatypeProperty ;
                 rdfs:domain ped:EnergyPrice ;
                 rdfs:range xsd:dateTimeStamp ;
                 rdfs:label "Has Time Stamp" .

ped:EnergyPerformanceScore rdf:type owl:DatatypeProperty ;
    rdfs:domain ped:EnergyPerformanceCertification;
    rdfs:range xsd:integer ;
    rdfs:label "EnergyPerformanceScore"@en .

ped:EnergyPerformanceCertificationUnits rdf:type owl:DatatypeProperty ;
    rdfs:domain ped:EnergyPerformanceCertification;
    rdfs:range xsd:string ;
    rdfs:label "EnergyPerformanceCertificationUnits"@en .


ped:hasPostalAddress rdf:type owl:ObjectProperty ;
                     rdfs:domain ped:Building ;
                     rdfs:domain ped:BuildingUnit;
                     rdfs:range ped:PostalAddress ;
                     rdfs:label "hasPostalAddress"@en .


ped:addressLine1 rdf:type owl:DatatypeProperty ;
                 rdfs:domain ped:PostalAddress ;
                 rdfs:range xsd:string ;
                 rdfs:label "addressLine1"@en .



ped:addressLine2 rdf:type owl:DatatypeProperty ;
                 rdfs:domain ped:PostalAddress ;
                 rdfs:range xsd:string ;
                 rdfs:label "addressLine2"@en .


ped:City rdf:type owl:DatatypeProperty ;
         rdfs:domain ped:PostalAddress ;
         rdfs:range xsd:string ;
         rdfs:label "City"@en .

###  https://pedvolution.eu/ontology/Country
ped:Country rdf:type owl:DatatypeProperty ;
            rdfs:domain ped:PostalAddress ;
            rdfs:range xsd:string ;
            rdfs:label "Country"@en .

###  https://pedvolution.eu/ontology/postalCode
ped:postalCode rdf:type owl:DatatypeProperty ;
               rdfs:domain ped:PostalAddress ;
               rdfs:range xsd:string ;
               rdfs:label "postalCode"@en .


ped:culturalClassification rdf:type owl:DatatypeProperty ;
                           rdfs:domain ped:Building ;
                           rdfs:range [ rdf:type rdfs:Datatype ;
                                        owl:oneOf [ rdf:type rdf:List ;
                                                    rdf:first "Archaeological" ;
                                                    rdf:rest [ rdf:type rdf:List ;
                                                               rdf:first "Architectural" ;
                                                               rdf:rest [ rdf:type rdf:List ;
                                                                          rdf:first "Heritage Site" ;
                                                                          rdf:rest [ rdf:type rdf:List ;
                                                                                     rdf:first "Historical" ;
                                                                                     rdf:rest [ rdf:type rdf:List ;
                                                                                                rdf:first "Modernist" ;
                                                                                                rdf:rest [ rdf:type rdf:List ;
                                                                                                           rdf:first "Religious" ;
                                                                                                           rdf:rest [ rdf:type rdf:List ;
                                                                                                                      rdf:first "UNESCO World Heritage" ;
                                                                                                                      rdf:rest rdf:nil
                                                                                                                    ]
                                                                                                         ]
                                                                                              ]
                                                                                   ]
                                                                        ]
                                                             ]
                                                  ]
                                      ] ;
                           rdfs:comment "The cultural classification of a building, chosen from a predefined list."@en ;
                           rdfs:label "Cultural Classification"@en .



ped:yearBuilt rdf:type owl:DatatypeProperty ;
              rdfs:domain ped:Building ;
              rdfs:range [ rdf:type rdfs:Datatype ;
                           owl:onDatatype xsd:integer ;
                           owl:withRestrictions ( [ xsd:minInclusive 1000
                                                  ]
                                                  [ xsd:maxInclusive 9999
                                                  ]
                                                )
                         ] ;
              rdfs:comment "Four-digit year that the building was first built." ;
              rdfs:label "Year built"@en .


ped:ShadingSystem rdf:type owl:DatatypeProperty ;
                  rdfs:domain ped:BuildingConstructionCharacteristics ;
                  rdfs:range [ rdf:type rdfs:Datatype ;
                               owl:oneOf [ rdf:type rdf:List ;
                                           rdf:first "Dynamic" ;
                                           rdf:rest [ rdf:type rdf:List ;
                                                      rdf:first "Fixed" ;
                                                      rdf:rest [ rdf:type rdf:List ;
                                                                 rdf:first "No Shading" ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ]
                             ] ;
                  rdfs:comment "The type of shading system."@en ;
                  rdfs:label "Shading System"@en .


ped:Total_Roof_Area_In_M2 rdf:type owl:DatatypeProperty ;
             rdfs:domain ped:RoofCharacteristics ;
             rdfs:range xsd:float ;
             rdfs:comment "Total roof area in M2."@en ;
             rdfs:label "Total roof area in M2"@en .


ped:Net_Roof_Window_Area_In_M2 rdf:type owl:DatatypeProperty ;
             rdfs:domain ped:RoofCharacteristics ;
             rdfs:range xsd:float ;
             rdfs:comment "Net roof window area in M2."@en ;
             rdfs:label "Net roof window area in M2"@en .


ped:hasRoofCharacteristics rdf:type owl:ObjectProperty ;
                                                rdfs:domain ped:BuildingConstructionCharacteristics ;
                                                rdfs:range  ped:RoofCharacteristics;
                                                rdfs:comment "Links roofcharacteristics to Building Construction Characteristics ";
                                                rdfs:label "has Roof Characteristics"   .


ped:WindowToWallRatio rdf:type owl:DatatypeProperty ;
                      rdfs:domain ped:WindowsCharacteristics ;
                      rdfs:range xsd:float ;
                      rdfs:comment "If available, the proportion of window area to the total wall area."@en ;
                      rdfs:label "WindowToWallRatio"@en .

ped:TotalWindowAreaInM2 rdf:type owl:DatatypeProperty ;
               rdfs:domain ped:WindowsCharacteristics;
               rdfs:range xsd:float;
               rdfs:comment "Total Window Area in m2";
               rdfs:label "Total Window Area In M2"@en .

ped:WindowType rdf:type owl:DatatypeProperty ;
               rdfs:domain ped:WindowsCharacteristics;
               rdfs:range [ rdf:type rdfs:Datatype ;
                            owl:oneOf [ rdf:type rdf:List ;
                                        rdf:first "Double-glazed" ;
                                        rdf:rest [ rdf:type rdf:List ;
                                                   rdf:first "Single" ;
                                                   rdf:rest [ rdf:type rdf:List ;
                                                              rdf:first "Triple-glazed" ;
                                                              rdf:rest rdf:nil
                                                            ]
                                                 ]
                                      ]
                          ] ;
               rdfs:comment "Type of windows used in the building  (Single, Double-glazed, Triple-glazed)."@en ;
               rdfs:label "WindowType"@en .


ped:RenovationYear rdf:type owl:DatatypeProperty ;
                   rdfs:domain ped:RenovationCharacteristics ;
                   rdfs:range [ rdf:type rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 1000
                                                       ]
                                                       [ xsd:maxInclusive 9999
                                                       ]
                                                     )
                              ] ;
                   rdfs:comment "Four-digit most recent year that the building was renovated (if applicable)." ;
                   rdfs:label "Renovation Year"@en .



ped:hasRenovationCharacteristics rdf:type owl:ObjectProperty ;
